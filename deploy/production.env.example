# Copy to deploy/production.env on ECS, chmod 600, and never commit the real file.
# Use the RDS internal endpoint and dedicated least-privilege accounts. The migration
# credential is injected only into the one-shot migrate container; the API receives
# only the DML application credential.
MIGRATION_DATABASE_URL=mysql://nearby_shop_migrator:URL_ENCODED_PASSWORD@RDS_INTERNAL_ENDPOINT:3306/nearby_shop
DATABASE_URL=mysql://nearby_shop_app:URL_ENCODED_PASSWORD@RDS_INTERNAL_ENDPOINT:3306/nearby_shop

# Generate independently on ECS. Do not reuse RDS, admin or WeChat passwords.
REDIS_PASSWORD=REPLACE_WITH_RANDOM_REDIS_PASSWORD
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

WECHAT_APP_ID=wxc44c68a305d7fd91
WECHAT_APP_SECRET=REPLACE_LOCALLY_WITH_ROTATED_SECRET

# Leave all payment values empty until the real merchant is linked. During key rotation,
# keep old and new ID-to-PEM entries together, then switch WECHAT_PAY_PUBLIC_KEY_ID.
# Escape PEM newlines as \\n so the JSON stays on one dotenv line.
WECHAT_MCH_ID=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_PUBLIC_KEYS_JSON=
# Set these together with all merchant credentials:
# https://api.surroundsmallshops.com/api/v1/payments/wechat/notify
# https://api.surroundsmallshops.com/api/v1/refunds/wechat/notify
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_REFUND_NOTIFY_URL=

CORS_ALLOWED_ORIGINS=https://www.surroundsmallshops.com
ADMIN_API_BASE_URL=https://api.surroundsmallshops.com/api/v1

# For a zero-downtime first cutover, choose unused ports such as 3110/8180,
# verify locally, then point BaoTa reverse proxies to them.
PRODUCTION_API_PORT=3100
PRODUCTION_HTTP_PORT=8080
