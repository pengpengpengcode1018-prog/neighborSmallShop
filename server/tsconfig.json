{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "target": "ES2023",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "generated", "node_modules", "tests"]
}
