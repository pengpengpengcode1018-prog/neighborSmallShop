NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://nearby_shop:nearby_shop_dev@127.0.0.1:3306/nearby_shop
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=28800
TRUST_PROXY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=600
AUTH_RATE_LIMIT_MAX_REQUESTS=20
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_DISPLAY_NAME=开发管理员
ADMIN_SEED_PASSWORD=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PUBLIC_KEY_ID=
# One-line JSON map. Escape PEM newlines as \\n. Keep the retiring and replacement
# keys together during rotation, and set WECHAT_PAY_PUBLIC_KEY_ID to the ID used for requests.
# Example: {"PUB_KEY_ID_xxx":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}
WECHAT_PAY_PUBLIC_KEYS_JSON=
# Deprecated single-key fallback for local compatibility. Do not set together with the JSON map.
WECHAT_PAY_PUBLIC_KEY=
WECHAT_PAY_NOTIFY_URL=https://example.com/api/v1/payments/wechat/notify
WECHAT_PAY_REFUND_NOTIFY_URL=https://example.com/api/v1/refunds/wechat/notify

# Subscription-message template IDs and keyword mappings are configured in the
# WeChat public platform. Keep this empty until real templates are approved.
# Example: {"ORDER_PAID":{"templateId":"template-id","fields":{"orderNo":"character_string1","status":"phrase2"}}}
WECHAT_SUBSCRIBE_TEMPLATES_JSON={}
WECHAT_MINIPROGRAM_STATE=developer

# Expired pending-order worker
EXPIRED_ORDER_JOB_ENABLED=true
EXPIRED_ORDER_JOB_INTERVAL_MS=30000
EXPIRED_ORDER_JOB_BATCH_SIZE=50
PAYMENT_CLOSE_LEASE_MS=30000

# Resident subscription delivery and admin-alert discovery worker
NOTIFICATION_JOB_ENABLED=true
NOTIFICATION_JOB_INTERVAL_MS=15000
NOTIFICATION_JOB_BATCH_SIZE=50
NOTIFICATION_RETRY_DELAY_MS=30000
NOTIFICATION_MAX_ATTEMPTS=3
ADMIN_ALERT_UNACCEPTED_MINUTES=10
